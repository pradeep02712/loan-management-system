# Root reference environment file
# The app reads environment variables from server/.env and client/.env.local.
# Copy the relevant sections into those files.

# Backend / server/.env
NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/lms
JWT_SECRET=replace-with-a-long-random-secret-for-local-development
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=uploads

# Frontend / client/.env.local
NEXT_PUBLIC_API_URL=http://localhost:4000/api
